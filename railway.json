{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build && pip install -r requirements.txt",
    "nixpacksPlan": {
      "providers": ["node", "python"],
      "variables": {
        "NODE_VERSION": "20"
      }
    }
  },
  "deploy": {
    "startCommand": "uvicorn server:app --host 0.0.0.0 --port $PORT"
  }
}
